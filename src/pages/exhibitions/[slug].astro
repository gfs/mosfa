---
import { Image } from 'astro:assets';
import type { ExhibitionViewEntry } from '../../lib/exhibitionViews';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getExhibitionViews } from '../../lib/exhibitionViews';
import { getImageAsset } from '../../lib/images';
import { slugifyTaxonomy } from '../../lib/taxonomy';
import { withBase } from '../../lib/paths';

export async function getStaticPaths() {
	return getExhibitionViews().map((view) => ({
		params: { slug: view.slug },
		props: { view },
	}));
}

interface Props {
	view: ExhibitionViewEntry;
}

const { view } = Astro.props;
const image = getImageAsset(view.image);
---

<BaseLayout title={`${view.title} | MOSFA`} description={view.summary}>
	<article class="exhibition-detail">
		<figure>
			<Image src={image} alt={view.imageAlt} />
			<figcaption>{view.summary}</figcaption>
		</figure>
		<div>
			<h2>{view.title}</h2>
			<p class="lede">{view.description}</p>
			<ul class="detail-meta">
				<li>
					<strong>Era:</strong>
					<a href={withBase(`/eras/${slugifyTaxonomy(view.era)}/`)}>
						{view.era}
					</a>
				</li>
				<li>
					<strong>Rooms:</strong> {view.categories.join(', ')}
				</li>
			</ul>
		</div>
	</article>
</BaseLayout>
