---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPublishedArtworks } from '../../lib/artworks';
import { groupByCategory, slugifyTaxonomy } from '../../lib/taxonomy';
import { withBase } from '../../lib/paths';

const artworks = await getPublishedArtworks();
const categories = groupByCategory(artworks);
---

<BaseLayout
	title="Categories | MoSFA"
	description="Browse the MoSFA collection grouped by category."
>
	<section>
		<h2>Categories</h2>
		<ul class="tax-list">
			{
				categories.map(([label, groupedArtworks]) => (
					<li>
						<a href={withBase(`/categories/${slugifyTaxonomy(label)}/`)}>
							<strong>{label}</strong>
							<span>{groupedArtworks.length} pieces</span>
						</a>
					</li>
				))
			}
		</ul>
	</section>
</BaseLayout>
