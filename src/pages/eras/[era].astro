---
import type { ArtworkEntry } from '../../lib/artworks';
import ArtworkGrid from '../../components/ArtworkGrid.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ExhibitionViewCard from '../../components/ExhibitionViewCard.astro';
import { getPublishedArtworks } from '../../lib/artworks';
import { getExhibitionViewsForEra } from '../../lib/exhibitionViews';
import { groupByEra, slugifyTaxonomy } from '../../lib/taxonomy';

export async function getStaticPaths() {
	const artworks = await getPublishedArtworks();
	const grouped = groupByEra(artworks);
	return grouped.map(([label, groupedArtworks]) => ({
		params: { era: slugifyTaxonomy(label) },
		props: { eraLabel: label, artworks: groupedArtworks },
	}));
}

interface Props {
	eraLabel: string;
	artworks: ArtworkEntry[];
}

const { eraLabel, artworks } = Astro.props;
const exhibitionViews = getExhibitionViewsForEra(eraLabel);
---

<BaseLayout
	title={`${eraLabel} | MoSFA`}
	description={`Browse artworks in the ${eraLabel} era.`}
>
	<section>
		<h2>{eraLabel}</h2>
		<p class="lede">
			{artworks.length} curated {artworks.length === 1 ? 'work' : 'works'} in this
			era.
		</p>
		<ArtworkGrid artworks={artworks} />
	</section>

	{
		exhibitionViews.length > 0 && (
			<section aria-labelledby="exhibition-heading">
				<h2 id="exhibition-heading">Exhibition Views</h2>
				<p class="lede">
					Rooms and survey walls connected to this part of the collection.
				</p>
				<div class="exhibition-grid">
					{exhibitionViews.map((view) => <ExhibitionViewCard view={view} />)}
				</div>
			</section>
		)
	}
</BaseLayout>
