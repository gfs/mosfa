---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArtworkGrid from '../components/ArtworkGrid.astro';
import ExhibitionViewCard from '../components/ExhibitionViewCard.astro';
import { getFeaturedArtworks, getPublishedArtworks } from '../lib/artworks';
import { getExhibitionViews } from '../lib/exhibitionViews';
import { groupByCategory, groupByEra, slugifyTaxonomy } from '../lib/taxonomy';
import { withBase } from '../lib/paths';

const artworks = await getPublishedArtworks();
const featured = getFeaturedArtworks(artworks);
const exhibitionViews = getExhibitionViews();
const eraGroups = groupByEra(artworks);
const categoryGroups = groupByCategory(artworks);
---

<BaseLayout
	title="MoSFA — Museum of Shrimp-Folk Art"
	description="A curated museum on Central Reef preserving the visual culture, artistic movements, and canon of shrimp-folk civilization."
>
	<section class="intro-section">
		<h2>Welcome to MoSFA</h2>
		<p class="lede">
			From 11 West Current Drive on Central Reef, the Museum of Shrimp-Folk
			Art preserves sacred images, civic emblems, studio experiments, poster
			rooms, and modernist breakthroughs from across shrimp-folk civilization.
		</p>
		<p>
			Across the collection, exoskeletal gesture, antennae linework, shell
			architecture, reef-city memory, and ritual form move through one
			continuous art history, gathered in New Atlantis for study, exhibition,
			and public care.
		</p>
	</section>

	<section aria-labelledby="featured-heading">
		<h2 id="featured-heading">Featured pieces</h2>
		<ArtworkGrid artworks={featured} />
	</section>

	<section aria-labelledby="exhibition-heading">
		<h2 id="exhibition-heading">Exhibition views</h2>
		<p class="lede">
			Rooms from the museum where individual works, posters, tools, and civic
			images gather into larger histories.
		</p>
		<div class="exhibition-grid">
			{exhibitionViews.map((view) => <ExhibitionViewCard view={view} />)}
		</div>
	</section>

	<section aria-labelledby="era-heading">
		<h2 id="era-heading">Browse by era</h2>
		<ul class="tax-list">
			{
				eraGroups.map(([label, groupedArtworks]) => (
					<li>
						<a href={withBase(`/eras/${slugifyTaxonomy(label)}/`)}>
							<strong>{label}</strong>
							<span>{groupedArtworks.length} pieces</span>
						</a>
					</li>
				))
			}
		</ul>
	</section>

	<section aria-labelledby="category-heading">
		<h2 id="category-heading">Browse by category</h2>
		<ul class="tax-list">
			{
				categoryGroups.map(([label, groupedArtworks]) => (
					<li>
						<a href={withBase(`/categories/${slugifyTaxonomy(label)}/`)}>
							<strong>{label}</strong>
							<span>{groupedArtworks.length} pieces</span>
						</a>
					</li>
				))
			}
		</ul>
	</section>
</BaseLayout>
