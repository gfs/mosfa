---
import type { ShopItem } from '../lib/shop';

interface Props {
  item: ShopItem;
}

const { item } = Astro.props;
---

<article class="shop-item-card">
  <div class="shop-item-head">
    <p class="artwork-meta">{item.wing} · {item.category}</p>
    <h3>{item.name}</h3>
  </div>
  <p class="shop-item-price">{item.priceLabel}</p>
  <p><strong>OUT OF STOCK — {item.unavailableLabel}</strong></p>
  <p>{item.description}</p>
  <p class="shop-item-note">Inventory note: {item.inventoryNote}</p>
  <button type="button" class="shop-item-button" disabled aria-disabled="true">Unavailable</button>
</article>
