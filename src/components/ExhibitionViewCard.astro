---
import { Image } from 'astro:assets';
import type { ExhibitionViewEntry } from '../lib/exhibitionViews';
import { getImageAsset } from '../lib/images';
import { withBase } from '../lib/paths';

interface Props {
	view: ExhibitionViewEntry;
}

const { view } = Astro.props;
const image = getImageAsset(view.image);
---

<article class="exhibition-card">
	<a href={withBase(`/exhibitions/${view.slug}/`)}>
		<Image
			src={image}
			alt={view.imageAlt}
			loading="lazy"
		/>
	</a>
	<div class="exhibition-card-body">
		<h3>
			<a href={withBase(`/exhibitions/${view.slug}/`)}>
				{view.title}
			</a>
		</h3>
		<p class="artwork-meta">{view.era}</p>
		<p>{view.summary}</p>
	</div>
</article>
