---
import { Image } from 'astro:assets';
import type { ArtworkEntry } from '../lib/artworks';
import { getImageAsset } from '../lib/images';
import { withBase } from '../lib/paths';

interface Props {
	artwork: ArtworkEntry;
	showImageFileTimestamp?: boolean;
}

const { artwork, showImageFileTimestamp = false } = Astro.props;
const image = getImageAsset(artwork.image);
const imageFileDate = artwork.imageFileTimestamp
	? new Intl.DateTimeFormat('en', {
			dateStyle: 'medium',
			timeZone: 'UTC',
		}).format(new Date(artwork.imageFileTimestamp))
	: undefined;
---

<article class="artwork-card">
	<a href={withBase(`/artworks/${artwork.slug}/`)}>
		<Image
			src={image}
			alt={artwork.imageAlt}
			loading="lazy"
		/>
	</a>
	<div class="artwork-card-body">
		<h3>
			<a href={withBase(`/artworks/${artwork.slug}/`)}>
				{artwork.title}
			</a>
		</h3>
		<p class="artwork-meta">
			{artwork.artistReference} · {artwork.era}
		</p>
		{
			showImageFileTimestamp && imageFileDate && (
				<p class="artwork-meta artwork-timestamp">Added {imageFileDate}</p>
			)
		}
		<p>{artwork.summary}</p>
	</div>
</article>
