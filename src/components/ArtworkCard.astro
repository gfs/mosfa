---
import { Image } from 'astro:assets';
import type { ArtworkEntry } from '../lib/artworks';
import { getImageAsset } from '../lib/images';
import { withBase } from '../lib/paths';

interface Props {
	artwork: ArtworkEntry;
}

const { artwork } = Astro.props;
const image = getImageAsset(artwork.image);
---

<article class="artwork-card">
	<a href={withBase(`/artworks/${artwork.slug}/`)}>
		<Image
			src={image}
			alt={artwork.imageAlt}
			loading="lazy"
		/>
	</a>
	<div class="artwork-card-body">
		<h3>
			<a href={withBase(`/artworks/${artwork.slug}/`)}>
				{artwork.title}
			</a>
		</h3>
		<p class="artwork-meta">
			{artwork.artistReference} · {artwork.era}
		</p>
		<p>{artwork.summary}</p>
	</div>
</article>
