---
import { Image, getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import logo from '../assets/images/logo.png';
import { withBase } from '../lib/paths';
import '../styles/global.css';

interface Props {
	title: string;
	description: string;
	socialImage?: string | ImageMetadata;
	socialImageAlt?: string;
}

const { title, description } = Astro.props;
const socialImageSource = Astro.props.socialImage ?? logo;
const socialImageAlt =
	Astro.props.socialImageAlt ?? 'Museum of Shrimp-Folk Art logo';
const optimizedSocialImage =
	typeof socialImageSource === 'string'
		? undefined
		: await getImage({
				src: socialImageSource,
				width: 1200,
				height: Astro.props.socialImage ? undefined : 630,
				fit: Astro.props.socialImage ? undefined : 'contain',
				background: Astro.props.socialImage ? undefined : '#f7f1e7',
				format: 'jpg',
				quality: 80,
			});
const socialImage = optimizedSocialImage?.src ?? socialImageSource;
const socialImageWidth = optimizedSocialImage?.attributes.width;
const socialImageHeight = optimizedSocialImage?.attributes.height;
const canonicalUrl = Astro.site
	? new URL(Astro.url.pathname, Astro.site).toString()
	: Astro.url.toString();
const socialImageUrl = Astro.site
	? new URL(socialImage, Astro.site).toString()
	: new URL(socialImage, Astro.url).toString();
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<link rel="icon" type="image/png" sizes="512x512" href={withBase('/favicon.png')} />
		<link rel="icon" type="image/png" sizes="32x32" href={withBase('/favicon-32.png')} />
		<link rel="icon" href={withBase('/favicon.ico')} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={socialImageUrl} />
		<meta property="og:image:alt" content={socialImageAlt} />
		{socialImageWidth && <meta property="og:image:width" content={String(socialImageWidth)} />}
		{socialImageHeight && <meta property="og:image:height" content={String(socialImageHeight)} />}
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={socialImageUrl} />
		<meta name="twitter:image:alt" content={socialImageAlt} />
		<script is:inline>
			(() => {
				const storageKey = 'mosfa-theme';
				const root = document.documentElement;
				const getStoredTheme = () => {
					try {
						const storedTheme = localStorage.getItem(storageKey);
						return storedTheme === 'dark' || storedTheme === 'light'
							? storedTheme
							: undefined;
					} catch {
						return undefined;
					}
				};
				const systemTheme = window.matchMedia('(prefers-color-scheme: dark)')
					.matches
					? 'dark'
					: 'light';
				const theme = getStoredTheme() ?? systemTheme;
				root.dataset.theme = theme;
				root.style.colorScheme = theme;
			})();
		</script>
	</head>
	<body>
		<a class="skip-link" href="#content">Skip to content</a>
		<header class="site-header">
			<div class="shell">
				<div class="site-header-row">
					<h1 class="site-title">
						<a class="brand-lockup" href={withBase('/')}>
							<Image src={logo} alt="" />
							<span class="visually-hidden">Museum of Shrimp-Folk Art</span>
						</a>
					</h1>
					<button
						class="theme-toggle"
						type="button"
						aria-label="Switch to dark mode"
						aria-pressed="false"
						title="Switch to dark mode"
						data-theme-toggle
					>
						<span class="theme-toggle-icon" aria-hidden="true"></span>
					</button>
				</div>
				<nav aria-label="Primary">
					<ul class="site-nav">
						<li><a href={withBase('/')}>Home</a></li>
						<li><a href={withBase('/about/')}>About</a></li>
						<li><a href={withBase('/gallery/')}>Gallery</a></li>
						<li><a href={withBase('/exhibitions/')}>Exhibitions</a></li>
						<li><a href={withBase('/eras/')}>Eras</a></li>
						<li><a href={withBase('/categories/')}>Categories</a></li>
					</ul>
				</nav>
			</div>
		</header>
		<main id="content" class="shell">
			<slot />
		</main>
		<footer class="site-footer shell">
			<p>
				© {new Date().getFullYear()} Museum of Shrimp-Folk Art · Curating
				the visual culture of shrimp-folk civilization.
			</p>
			<p>
				<a href={withBase('/about/')}>11 West Current Drive · Central Reef District · New Atlantis, NA 10024</a>
			</p>
		</footer>
		<script is:inline>
			(() => {
				const storageKey = 'mosfa-theme';
				const root = document.documentElement;
				const button = document.querySelector('[data-theme-toggle]');

				if (!(button instanceof HTMLButtonElement)) {
					return;
				}

				const updateButton = (theme) => {
					const nextTheme = theme === 'dark' ? 'light' : 'dark';
					button.setAttribute('aria-pressed', String(theme === 'dark'));
					button.setAttribute('aria-label', `Switch to ${nextTheme} mode`);
					button.title = `Switch to ${nextTheme} mode`;
				};

				const setTheme = (theme) => {
					root.dataset.theme = theme;
					root.style.colorScheme = theme;
					updateButton(theme);
				};

				setTheme(root.dataset.theme === 'dark' ? 'dark' : 'light');

				button.addEventListener('click', () => {
					const theme = root.dataset.theme === 'dark' ? 'light' : 'dark';
					setTheme(theme);

					try {
						localStorage.setItem(storageKey, theme);
					} catch {
						/* Theme still changes for the current page when storage is blocked. */
					}
				});
			})();
		</script>
	</body>
</html>
